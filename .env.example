# CAESAR environment variables.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# See docs/CONFIGURATION.md for the full reference.

# --- Praetor (central brain) ---
CAESAR_ENV=development              # development | staging | production
CAESAR_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
CAESAR_HTTP_HOST=127.0.0.1
CAESAR_HTTP_PORT=8088

# --- Home Assistant Bridge ---
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=                # long-lived access token

# --- Message bus (NATS, per ADR-0009) ---
NATS_URL=nats://127.0.0.1:4222

# --- LLM Gateway: provider credentials (set only what you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
VLLM_BASE_URL=

# --- Memory ---
CAESAR_SQLITE_PATH=./var/caesar.sqlite
CAESAR_VECTOR_BACKEND=sqlite-vss     # sqlite-vss | qdrant | chroma
QDRANT_URL=

# --- Voice Satellite (Wyoming) ---
WYOMING_HOST=0.0.0.0
WYOMING_PORT=10300
