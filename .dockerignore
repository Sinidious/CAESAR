# Keep the build context small + reproducible (ADR-0029).
# Anything not listed under COPY in the Dockerfile gets ignored.

.git/
.github/
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
site/                     # mkdocs build output
var/                      # operator state; never bundled into images
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm

# Tests and dev surfaces aren't needed at runtime.
tests/
docs/
examples/
mkdocs.yml
.pre-commit-config.yaml

# IDE / editor scratch.
.vscode/
.idea/
*.swp

# Anything in node_modules/ from a future dashboard build.
node_modules/
